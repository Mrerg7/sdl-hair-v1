---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — sdl.hair" description="The requested page could not be found on sdl.hair. Return to the homepage.">
  <div class="min-h-screen flex items-center justify-center bg-slate-50 px-6">
    <div class="text-center max-w-md">
      <div class="text-8xl font-bold tracking-tighter text-slate-200 mb-4">404</div>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 mb-3">Page Not Found</h1>
      <p class="text-slate-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a
        href="/"
        class="inline-flex items-center px-8 py-3 bg-slate-900 hover:bg-black text-white font-semibold rounded-3xl text-sm transition-all"
      >
        Back to sdl.hair
      </a>
    </div>
  </div>
</BaseLayout>
