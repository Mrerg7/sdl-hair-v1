---
import CtaButton from './CtaButton.astro';
---

<nav class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex justify-between items-center h-20">
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 bg-slate-900 rounded-2xl flex items-center justify-center">
          <span class="text-white font-bold text-2xl tracking-tighter">SDL</span>
        </div>
        <div class="font-semibold text-xl tracking-tighter text-slate-900">
          sdl<span class="text-amber-700">.</span>hair
        </div>
      </div>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#why" class="nav-link text-slate-600 hover:text-slate-900">Why This Domain</a>
        <a href="#perfect-for" class="nav-link text-slate-600 hover:text-slate-900">Perfect For</a>
        <a href="#acquire" class="nav-link text-slate-600 hover:text-slate-900">Acquire</a>
      </div>

      <div class="flex items-center gap-x-3">
        <CtaButton
          variant="default"
          size="sm"
          label="Make an Offer"
          href="#acquire"
        />
      </div>
    </div>
  </div>
</nav>
