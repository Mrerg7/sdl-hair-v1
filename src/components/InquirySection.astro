---
import { SITE } from '../config/site';
---

<div class="bg-slate-900 py-16" id="inquire">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-10">
      <div class="inline px-4 py-1 rounded-3xl bg-white/10 text-white text-xs tracking-[1.5px] font-medium mb-4">
        SERIOUS INQUIRIES ONLY
      </div>
      <h2 class="text-white text-4xl md:text-5xl tracking-tighter font-semibold">Ready to own sdl.hair?</h2>
      <p class="mt-4 text-white/70 max-w-md mx-auto">
        Premium domains in this category move quickly. Submit your inquiry below and we&rsquo;ll respond promptly with
        details and next steps.
      </p>
    </div>

    <form
      id="inquiry-form"
      onsubmit="submitInquiry(event)"
      class="inquiry-form bg-white rounded-3xl p-8 md:p-10 shadow-xl"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-2">YOUR NAME</label>
          <input
            type="text" id="name" required placeholder="Alex Rivera"
            class="w-full border border-slate-200 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-400 focus:border-amber-700 focus:ring-3 focus:ring-amber-700/10 outline-none transition-all"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-2">EMAIL ADDRESS</label>
          <input
            type="email" id="email" required placeholder="you@yourbrand.com"
            class="w-full border border-slate-200 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-400 focus:border-amber-700 focus:ring-3 focus:ring-amber-700/10 outline-none transition-all"
          />
        </div>
      </div>

      <div class="mt-6">
        <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-2">INTENDED USE FOR sdl.hair</label>
        <select
          id="use-case" required
          class="w-full border border-slate-200 rounded-2xl px-5 py-3.5 text-sm text-slate-700 focus:border-amber-700 focus:ring-3 focus:ring-amber-700/10 outline-none transition-all"
        >
          <option value="">Select best fit...</option>
          <option>Luxury Hair Salon or Salon Group (Scottsdale focus)</option>
          <option>Premium Hair Care / Treatment Brand</option>
          <option>Hair Extensions, Wigs or Halo Hair Brand</option>
          <option>Hair Wellness, Restoration or Trichology Practice</option>
          <option>Personal Brand – Top Stylist / Influencer</option>
          <option>Beauty Destination, Resort or Members Club</option>
          <option>Other (please describe below)</option>
        </select>
      </div>

      <div class="mt-6">
        <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-2">YOUR OFFER (USD)</label>
        <div class="relative">
          <div class="absolute left-5 top-3.5 text-slate-400">$</div>
          <input
            type="number" id="offer" placeholder="15000" min="5000" step="500"
            class="w-full border border-slate-200 rounded-2xl pl-9 pr-5 py-3.5 text-sm placeholder:text-slate-400 focus:border-amber-700 focus:ring-3 focus:ring-amber-700/10 outline-none transition-all"
          />
        </div>
        <div class="text-[10px] text-slate-400 mt-1.5 px-1">
          Serious offers only. Comparable premium short .hair and beauty domains trade in the mid-to-high five figures.
        </div>
      </div>

      <div class="mt-6">
        <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-2">ADDITIONAL DETAILS OR VISION (OPTIONAL)</label>
        <textarea
          id="message" rows="3" placeholder="Planning to launch a flagship salon in North Scottsdale with an extension and color focus..."
          class="w-full border border-slate-200 rounded-2xl px-5 py-3.5 text-sm placeholder:text-slate-400 resize-y focus:border-amber-700 focus:ring-3 focus:ring-amber-700/10 outline-none transition-all"
        ></textarea>
      </div>

      <div class="mt-8">
        <button
          type="submit"
          class="w-full py-4 bg-slate-900 hover:bg-black active:bg-slate-950 transition-all text-white font-semibold rounded-3xl text-base tracking-wide"
        >
          SUBMIT INQUIRY
        </button>
      </div>

      <p class="text-center text-xs text-slate-400 mt-5">We typically respond within 24–48 hours. All inquiries are confidential.</p>
    </form>
  </div>
</div>
