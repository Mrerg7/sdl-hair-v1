---
export interface Props {
  class?: string;
  variant?: 'default' | 'gradient' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  label?: string;
  href?: string;
}

const { class: className = '', variant = 'default', size = 'md', label = 'Inquire', href } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-semibold transition-all active:scale-[0.985]';

const variantClasses: Record<string, string> = {
  default: 'bg-slate-900 hover:bg-black active:bg-slate-950 text-white',
  gradient: 'bg-gradient-to-r from-amber-600 to-amber-700 hover:from-amber-500 hover:to-amber-600 text-white shadow-lg',
  outline: 'border border-slate-300 hover:bg-slate-100 text-slate-700',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-5 py-2 text-xs rounded-2xl',
  md: 'px-8 py-3 text-sm rounded-3xl',
  lg: 'px-10 py-4 text-base rounded-3xl',
};

const Tag = href ? 'a' : 'button';
const tagProps = href ? { href } : {};
---

<Tag {...tagProps} class={`${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`}>
  {label}
</Tag>
