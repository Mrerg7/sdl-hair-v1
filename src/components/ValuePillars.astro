---
import { getCollection } from 'astro:content';

const valuePillars = await getCollection('value-pillars');
const sorted = valuePillars.sort((a, b) => a.data.order - b.data.order);
---

<div class="max-w-5xl mx-auto px-6 pt-16 pb-12" id="why">
  <div class="max-w-2xl">
    <div class="uppercase tracking-[2px] text-xs font-semibold text-amber-700 mb-3">THE OPPORTUNITY</div>
    <h2 class="text-5xl tracking-tighter font-semibold heading-serif">Own a standout<br />digital flagship in hair.</h2>
    <p class="mt-5 text-lg text-slate-600">
      sdl.hair is short, elegant, instantly memorable, and perfectly aligned with the multi-billion-dollar global hair
      care, salon, and beauty industry. The &ldquo;SDL&rdquo; prefix carries natural prestige — especially powerful when
      tied to Scottsdale, one of the wealthiest and most style-conscious markets in the United States.
    </p>
  </div>

  <div class="mt-12 grid md:grid-cols-3 gap-5">
    {sorted.map((pillar) => (
      <div class="value-card bg-white border border-slate-200 rounded-3xl p-7">
        <div class="text-amber-700 text-xs tracking-widest font-semibold mb-3">{pillar.data.tag}</div>
        <div class="font-semibold text-xl tracking-tight">{pillar.data.title}</div>
        <p class="mt-3 text-sm text-slate-600">{pillar.data.description}</p>
      </div>
    ))}
  </div>
</div>
